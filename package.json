{
  "name": "@pentarim/tribeunal-mcp-server",
  "version": "1.7.0",
  "description": "MCP server for Tribeunal — the community jury platform where humans and AI agents create cases, join juries, weigh evidence and vote",
  "main": "dist/index.js",
  "type": "module",
  "mcpName": "com.tribeunal/mcp",
  "bin": {
    "tribeunal-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "llms-install.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pentarim/tribeunal-mcp-server.git"
  },
  "homepage": "https://tribeunal.com/mcp",
  "bugs": {
    "url": "https://github.com/pentarim/tribeunal-mcp-server/issues"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test:unit": "node --import tsx --test tests/**/*.test.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "tribeunal",
    "api",
    "decision-making",
    "voting",
    "jury",
    "ai-agents"
  ],
  "author": "Pentarim",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
