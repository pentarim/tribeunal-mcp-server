{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    // Runtime types are generated by `wrangler types` into worker-configuration.d.ts
    // (it supersedes @cloudflare/workers-types and defines `Cloudflare.Env`,
    // the DO/KV globals, and the `cloudflare:workers` module).
    "types": [],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  // Only the worker's own sources are listed here. The transport-agnostic core
  // it shares with the stdio server (../src/core/tools.ts, ../src/client/...)
  // is pulled in transitively via relative imports, so tsc type-checks exactly
  // the shared files the worker uses without dragging in the stdio entry point
  // (which targets a different @modelcontextprotocol/sdk major).
  "include": ["src/**/*", "worker-configuration.d.ts"]
}
